rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: portfolio
    // Document ID: data
    // Fields: All string fields for portfolio display

    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && request.auth.token.email == "tjrgns421@gmail.com" && request.auth.token.email_verified == true;
    }

    match /portfolio/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
